{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus-Datasource, die den Pushgateway scraped",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Cosy Domain Provider — Systemtests",
  "uid": "cosy-systemtests",
  "tags": ["cosy", "systemtest", "e2e"],
  "timezone": "",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-7d", "to": "now" },
  "refresh": "5m",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Suite-Status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 16, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "cosy_systemtest_suite_success",
          "legendFormat": "{{suite}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "textMode": "value_and_name",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Letzter Lauf (Alter)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - cosy_systemtest_last_run_timestamp_seconds",
          "legendFormat": "seit letztem Lauf",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 93600 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "bargauge",
      "title": "Test-Ergebnisse pro Suite",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "cosy_systemtest_suite_tests_passed", "legendFormat": "passed {{suite}}", "instant": true },
        { "refId": "B", "expr": "cosy_systemtest_suite_tests_failed", "legendFormat": "failed {{suite}}", "instant": true },
        { "refId": "C", "expr": "cosy_systemtest_suite_tests_skipped", "legendFormat": "skipped {{suite}}", "instant": true }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "min": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Laufzeit pro Suite",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "cosy_systemtest_suite_duration_seconds", "legendFormat": "{{suite}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    }
  ]
}
